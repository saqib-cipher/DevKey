<?xml version="1.0" encoding="utf-8"?>
<!--
    styles.xml
    ──────────────────────────────────────────────────────────────────────────
    Material 3 Expressive theme + reusable widget styles for the CodeKeys IME.

    The keyboard layouts reference these styles so every key, chip, card and
    text field shares a consistent M3-Expressive look. Runtime code still
    overrides individual colors based on the user's selected theme — these
    styles only define the *baseline* look used at inflation time.
    ──────────────────────────────────────────────────────────────────────────
-->
<resources>

    <!--
        App theme — Material 3 dynamic palette. Day/Night auto-switches
        between light and dark Material You colors. Used by both the
        Settings activity and (transitively) the IME's inflated views so
        ?attr/colorSurface, ?attr/colorPrimaryContainer, etc. resolve.
    -->
    <style name="AppTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
    </style>

    <!--
        ─── Keyboard keys ───────────────────────────────────────────────────
        Default key (letters, numbers, symbols). Surface-variant fill,
        rounded corners, ripple primary, balanced touch padding.
    -->
    <style name="KeyboardKey" parent="Widget.Material3Expressive.Button">
        <item name="cornerRadius">@dimen/key_corner_radius</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:paddingTop">@dimen/key_padding_v</item>
        <item name="android:paddingBottom">@dimen/key_padding_v</item>
        <item name="android:paddingLeft">@dimen/key_padding_h</item>
        <item name="android:paddingRight">@dimen/key_padding_h</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:elevation">2dp</item>
        <item name="backgroundTint">?attr/colorSurfaceVariant</item>
        <item name="rippleColor">?attr/colorPrimary</item>
    </style>

    <!--
        Special key (Enter, Space, Caps, action keys) — primary container
        fill so the user instinctively recognises them as "non-letter".
    -->
    <style name="KeyboardKey.Special">
        <item name="backgroundTint">?attr/colorPrimaryContainer</item>
        <item name="android:textColor">?attr/colorOnPrimaryContainer</item>
    </style>

    <!--
        Icon-only key (settings cog, emoji, symbol toggle, arrows). Square
        footprint, slightly smaller corner radius to feel more "compact".
    -->
    <style name="KeyboardKey.Icon" parent="Widget.Material3Expressive.Button.IconButton">
        <item name="cornerRadius">@dimen/key_corner_radius</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="iconTint">?attr/colorOnSurface</item>
        <item name="rippleColor">?attr/colorPrimary</item>
    </style>

    <!--
        Suggestion-strip chip. Pill-shaped (radius 18dp), surface-variant
        fill, primary-container highlight handled in code by swapping the
        `backgroundTint` to ?attr/colorPrimaryContainer.
    -->
    <style name="SuggestionChip" parent="Widget.Material3Expressive.Button">
        <item name="cornerRadius">@dimen/chip_corner_radius</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:paddingLeft">12dp</item>
        <item name="android:paddingRight">12dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
        <item name="backgroundTint">?attr/colorSurfaceVariant</item>
        <item name="rippleColor">?attr/colorPrimary</item>
        <item name="android:elevation">0dp</item>
    </style>

    <!--
        Settings activity headers (kept for backwards compatibility with
        the existing Settings layout).
    -->
    <style name="SettingsHeader">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.15</item>
        <item name="android:layout_marginTop">22dp</item>
        <item name="android:layout_marginBottom">6dp</item>
        <item name="android:layout_marginStart">4dp</item>
    </style>

</resources>
