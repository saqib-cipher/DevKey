<?xml version="1.0" encoding="utf-8"?>
<!--
    Common styles used by the Settings activity layout.
    The activity also overrides several colors at runtime so that the user's
    selected theme is honored.
-->
<resources>

    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
    </style>

    <style name="SettingsHeader">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">#9494B5</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.15</item>
        <item name="android:layout_marginTop">22dp</item>
        <item name="android:layout_marginBottom">6dp</item>
        <item name="android:layout_marginStart">4dp</item>
    </style>

</resources>
