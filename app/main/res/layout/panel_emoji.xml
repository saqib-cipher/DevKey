<?xml version="1.0" encoding="utf-8"?>
<!--
    panel_emoji.xml — Emoji panel: search bar + scrollable category tabs +
    8-column emoji grid + a backspace button so the user can correct typos
    in the search query without leaving the panel.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Top: live search query -->
    <LinearLayout
        android:id="@+id/emoji_search_bar"
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#141428"
        android:paddingStart="10dp"
        android:paddingEnd="6dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔍"
            android:textSize="13sp"
            android:paddingEnd="6dp" />

        <TextView
            android:id="@+id/emoji_search_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="13sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:textColor="#9DA0BF"
            android:text="Type to search emoji…" />

        <Button
            android:id="@+id/emoji_search_clear"
            android:layout_width="36dp"
            android:layout_height="32dp"
            android:text="✕"
            android:textSize="12sp"
            android:textColor="#E8E8FF"
            android:background="@android:color/transparent"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Category tabs (horizontal, scrollable) -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:scrollbars="none"
        android:background="#0D0D1F">

        <LinearLayout
            android:id="@+id/emoji_category_tabs"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:gravity="center_vertical" />
    </HorizontalScrollView>

    <!-- 8-column emoji grid: vertical column of 4 rows of 8 emojis each.
         The grid scrolls vertically inside a ScrollView so all emojis in
         a category remain reachable. -->
    <ScrollView
        android:id="@+id/emoji_grid_scroll"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/emoji_grid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />
    </ScrollView>
</LinearLayout>
