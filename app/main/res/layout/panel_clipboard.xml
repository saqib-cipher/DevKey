<?xml version="1.0" encoding="utf-8"?>
<!--
    panel_clipboard.xml — Clipboard history panel.
    Header bar with "Copy selection" and "Clear unpinned" actions, then a
    vertically-scrolling list of clipboard cards. Each card has rounded
    corners and a 2-line preview; tap pastes, long-press deletes, the pin
    icon toggles "stick to top".
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Header strip -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#141428"
        android:paddingStart="12dp"
        android:paddingEnd="6dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Clipboard"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#E8E8FF" />

        <Button
            android:id="@+id/clip_copy_selection"
            android:layout_width="78dp"
            android:layout_height="34dp"
            android:text="⧉ Copy"
            android:textSize="11sp"
            android:textAllCaps="false"
            android:textColor="#00E5FF"
            android:background="#1F1F3D"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/clip_clear_all"
            android:layout_width="78dp"
            android:layout_height="34dp"
            android:text="✕ Clear"
            android:textSize="11sp"
            android:textAllCaps="false"
            android:textColor="#FF6666"
            android:background="#220F0F" />
    </LinearLayout>

    <!-- Card list -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/clip_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp" />
    </ScrollView>
</LinearLayout>
