<?xml version="1.0" encoding="utf-8"?>
<!--
    panel_clipboard.xml — clipboard history panel.
    Material 3 Expressive: header bar with "Copy selection" / "Clear unpinned"
    MaterialButtons, then a vertically-scrolling list of MaterialCardView
    items (built at runtime by `UIRenderer.fillClipboardPanel()`).
    Each card has rounded corners, a 2-line preview, tap-to-paste, long-press
    to delete, and a pin toggle.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- ── Header strip ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/clipboard_header_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="?attr/colorSurface"
        android:paddingStart="12dp"
        android:paddingEnd="6dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Clipboard"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/clip_copy_selection"
            style="@style/KeyboardKey"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:layout_marginEnd="4dp"
            android:text="⧉ Copy"
            android:textSize="11sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/clip_clear_all"
            style="@style/KeyboardKey"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="✕ Clear"
            android:textSize="11sp"
            app:backgroundTint="?attr/colorErrorContainer"
            android:textColor="?attr/colorOnErrorContainer" />
    </LinearLayout>

    <!-- ── Card list (runtime-filled) ── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="@dimen/clipboard_list_height"
        android:scrollbars="none"
        android:fillViewport="true"
        android:background="?attr/colorSurface">

        <LinearLayout
            android:id="@+id/clip_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp" />
    </ScrollView>
</LinearLayout>
