<?xml version="1.0" encoding="utf-8"?>
<!--
    keyboard_main.xml
    Place in: app/src/main/res/layout/keyboard_main.xml
    ──────────────────────────────────────────────────────────────────────────
    M3-Expressive coding keyboard.
    Adds a suggestion strip, drops the Tab key, brings in dedicated symbol
    and emoji panel buttons, and replaces the language label with a single
    settings/language popup trigger (gear icon).
    ──────────────────────────────────────────────────────────────────────────
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/keyboard_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="4dp"
    android:paddingBottom="6dp"
    android:background="#1A1A2E">

    <!-- ══════════════════════════════════════════════════════
         ROW −1 ─ Suggestion strip (autocomplete / correction)
    ══════════════════════════════════════════════════════ -->
    <HorizontalScrollView
        android:id="@+id/suggestion_scroll"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:scrollbars="none"
        android:background="#141428">

        <LinearLayout
            android:id="@+id/row_suggestions"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="6dp"
            android:paddingEnd="6dp" />
    </HorizontalScrollView>

    <!-- ══════════════════════════════════════════════════════
         ROW 0 ─ Numbers (1–0)
    ══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/row_numbers"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp" />

    <!-- ══════════════════════════════════════════════════════
         ROW 1 ─ QWERTY top row
    ══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/row_letters1"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp" />

    <!-- ══════════════════════════════════════════════════════
         ROW 2 ─ ASDFG row
    ══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/row_letters2"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp" />

    <!-- ══════════════════════════════════════════════════════
         ROW 3 ─ ZXCVB row + Caps + Backspace
    ══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <Button
            android:id="@+id/btn_caps"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="⇧"
            android:textSize="16sp"
            android:textColor="#E8E8FF"
            android:background="#252545"
            android:padding="2dp" />

        <LinearLayout
            android:id="@+id/row_letters3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="horizontal" />

        <Button
            android:id="@+id/btn_backspace"
            android:layout_width="52dp"
            android:layout_height="44dp"
            android:text="⌫"
            android:textSize="16sp"
            android:textColor="#E8E8FF"
            android:background="#252545"
            android:padding="2dp" />
    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════
         ROW 4 ─ Symbol toolbar (scrollable)
    ══════════════════════════════════════════════════════ -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:scrollbars="none"
        android:background="#141428">

        <LinearLayout
            android:id="@+id/row_symbols"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingEnd="4dp" />
    </HorizontalScrollView>

    <!-- ══════════════════════════════════════════════════════
         ROW 5 ─ Snippet shortcuts (scrollable)
    ══════════════════════════════════════════════════════ -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:scrollbars="none"
        android:background="#0D0D1F">

        <LinearLayout
            android:id="@+id/row_snippets"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingEnd="4dp" />
    </HorizontalScrollView>

    <!-- ══════════════════════════════════════════════════════
         ROW 6 ─ Bottom action row
         Lang+Settings | Symbols | Emoji | Undo | Redo | Space | Arrows | Enter
    ══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/row_nav"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:gravity="center_vertical">

        <!-- Settings / Language popup trigger -->
        <Button
            android:id="@+id/btn_settings"
            android:layout_width="46dp"
            android:layout_height="40dp"
            android:text="⚙"
            android:textSize="16sp"
            android:textColor="#00E5FF"
            android:background="#252545"
            android:padding="0dp" />

        <!-- Symbols panel toggle (replaces TAB) -->
        <Button
            android:id="@+id/btn_symbols_panel"
            android:layout_width="42dp"
            android:layout_height="40dp"
            android:text="?123"
            android:textSize="11sp"
            android:textColor="#E8E8FF"
            android:background="#252545"
            android:layout_marginStart="2dp" />

        <!-- Emoji panel -->
        <Button
            android:id="@+id/btn_emoji"
            android:layout_width="42dp"
            android:layout_height="40dp"
            android:text="☺"
            android:textSize="16sp"
            android:textColor="#E8E8FF"
            android:background="#252545"
            android:layout_marginStart="2dp" />

        <!-- Undo -->
        <Button
            android:id="@+id/btn_undo"
            android:layout_width="38dp"
            android:layout_height="40dp"
            android:text="↩"
            android:textSize="14sp"
            android:textColor="#E8E8FF"
            android:background="#252545"
            android:layout_marginStart="2dp" />

        <!-- Redo -->
        <Button
            android:id="@+id/btn_redo"
            android:layout_width="38dp"
            android:layout_height="40dp"
            android:text="↪"
            android:textSize="14sp"
            android:textColor="#E8E8FF"
            android:background="#252545"
            android:layout_marginStart="2dp" />

        <!-- Space -->
        <Button
            android:id="@+id/btn_space"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="space"
            android:textSize="12sp"
            android:textColor="#E8E8FF"
            android:background="#252545"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp" />

        <!-- Arrow cluster (vertical) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btn_arrow_up"
                android:layout_width="34dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:src="@android:drawable/arrow_up_float"
                android:background="#252545"
                android:scaleType="fitCenter" />

            <ImageButton
                android:id="@+id/btn_arrow_down"
                android:layout_width="34dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:src="@android:drawable/arrow_down_float"
                android:background="#252545"
                android:scaleType="fitCenter" />
        </LinearLayout>

        <!-- Arrow cluster (horizontal) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:orientation="vertical"
            android:layout_marginStart="1dp">

            <ImageButton
                android:id="@+id/btn_arrow_left"
                android:layout_width="34dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:src="@android:drawable/ic_media_rew"
                android:background="#252545"
                android:scaleType="fitCenter" />

            <ImageButton
                android:id="@+id/btn_arrow_right"
                android:layout_width="34dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:src="@android:drawable/ic_media_ff"
                android:background="#252545"
                android:scaleType="fitCenter" />
        </LinearLayout>

        <!-- Enter / IME action -->
        <Button
            android:id="@+id/btn_enter"
            android:layout_width="58dp"
            android:layout_height="40dp"
            android:text="↵"
            android:textSize="14sp"
            android:textColor="#00E5FF"
            android:background="#252545"
            android:layout_marginStart="2dp"
            android:padding="0dp"
            android:singleLine="true" />
    </LinearLayout>

</LinearLayout>
