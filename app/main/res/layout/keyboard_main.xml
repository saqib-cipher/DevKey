<?xml version="1.0" encoding="utf-8"?>
<!--
    keyboard_main.xml
    Place in: app/src/main/res/layout/keyboard_main.xml
    ──────────────────────────────────────────────────────────────────────────
    Material-3-expressive coding keyboard.

    Architecture:
      • Suggestion strip (chips) — always at the top.
      • Optional PC keys row — togglable from settings.
      • Single content container (FrameLayout) — the active panel view (keyboard /
        emoji / clipboard / symbols) is swapped inside this container instead of
        rebuilding the whole keyboard each time.
      • Bottom action row — caps/space/enter/arrows/etc., always visible.

    The container's height is roughly fixed (5 keyboard rows × scaled key
    height) so panel switches don't make the keyboard "jump" vertically.
    ──────────────────────────────────────────────────────────────────────────
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/keyboard_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="4dp"
    android:paddingBottom="6dp"
    android:background="#1A1A2E">

    <!-- ══════════════════════════════════════════════════════
         Suggestion strip (autocomplete chips)
    ══════════════════════════════════════════════════════ -->
    <HorizontalScrollView
        android:id="@+id/suggestion_scroll"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:scrollbars="none"
        android:background="#141428">

        <LinearLayout
            android:id="@+id/row_suggestions"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />
    </HorizontalScrollView>

    <!-- ══════════════════════════════════════════════════════
         Optional PC keys row — Esc Tab Ctrl Alt Shift Win F1–F12 …
         Toggleable from settings ("show_pc_keys"). Hidden by default.
    ══════════════════════════════════════════════════════ -->
    <HorizontalScrollView
        android:id="@+id/pc_keys_scroll"
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:scrollbars="none"
        android:background="#0F0F22"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/row_pc_keys"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="4dp" />
    </HorizontalScrollView>

    <!-- ══════════════════════════════════════════════════════
         Single panel container — the active panel view is swapped
         in here at runtime. Keeping this as a fixed-height frame
         (sized in code based on key_height_scale) prevents jumps
         when switching between keyboard / emoji / clipboard.
    ══════════════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/panel_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent" />

    <!-- ══════════════════════════════════════════════════════
         Bottom action row — caps/symbols/emoji/space/arrows/enter.
         Always visible regardless of the active panel.
    ══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/row_nav"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:layout_marginTop="2dp"
        android:gravity="center_vertical">

        <!-- Settings / Language popup trigger -->
        <Button
            android:id="@+id/btn_settings"
            android:layout_width="44dp"
            android:layout_height="42dp"
            android:text="⚙"
            android:textSize="16sp"
            android:textColor="#00E5FF"
            android:background="#252545"
            android:padding="0dp" />

        <!-- Symbols panel toggle (?123) -->
        <Button
            android:id="@+id/btn_symbols_panel"
            android:layout_width="44dp"
            android:layout_height="42dp"
            android:text="?123"
            android:textSize="11sp"
            android:textColor="#E8E8FF"
            android:background="#252545"
            android:layout_marginStart="3dp" />

        <!-- Emoji panel -->
        <Button
            android:id="@+id/btn_emoji"
            android:layout_width="44dp"
            android:layout_height="42dp"
            android:text="☺"
            android:textSize="16sp"
            android:textColor="#E8E8FF"
            android:background="#252545"
            android:layout_marginStart="3dp" />

        <!-- Undo -->
        <Button
            android:id="@+id/btn_undo"
            android:layout_width="38dp"
            android:layout_height="42dp"
            android:text="↩"
            android:textSize="14sp"
            android:textColor="#E8E8FF"
            android:background="#252545"
            android:layout_marginStart="3dp" />

        <!-- Space -->
        <Button
            android:id="@+id/btn_space"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:text="space"
            android:textSize="12sp"
            android:textColor="#E8E8FF"
            android:background="#252545"
            android:layout_marginStart="3dp"
            android:layout_marginEnd="3dp" />

        <!-- Redo -->
        <Button
            android:id="@+id/btn_redo"
            android:layout_width="38dp"
            android:layout_height="42dp"
            android:text="↪"
            android:textSize="14sp"
            android:textColor="#E8E8FF"
            android:background="#252545"
            android:layout_marginStart="3dp" />

        <!-- Arrow cluster (vertical: up/down) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:orientation="vertical"
            android:layout_marginStart="3dp">

            <ImageButton
                android:id="@+id/btn_arrow_up"
                android:layout_width="32dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:src="@android:drawable/arrow_up_float"
                android:background="#252545"
                android:scaleType="fitCenter" />

            <ImageButton
                android:id="@+id/btn_arrow_down"
                android:layout_width="32dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:src="@android:drawable/arrow_down_float"
                android:background="#252545"
                android:scaleType="fitCenter" />
        </LinearLayout>

        <!-- Arrow cluster (vertical: left/right) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:orientation="vertical"
            android:layout_marginStart="2dp">

            <ImageButton
                android:id="@+id/btn_arrow_left"
                android:layout_width="32dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:src="@android:drawable/ic_media_rew"
                android:background="#252545"
                android:scaleType="fitCenter" />

            <ImageButton
                android:id="@+id/btn_arrow_right"
                android:layout_width="32dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:src="@android:drawable/ic_media_ff"
                android:background="#252545"
                android:scaleType="fitCenter" />
        </LinearLayout>

        <!-- Enter / IME action -->
        <Button
            android:id="@+id/btn_enter"
            android:layout_width="58dp"
            android:layout_height="42dp"
            android:text="↵"
            android:textSize="14sp"
            android:textColor="#00E5FF"
            android:background="#252545"
            android:layout_marginStart="3dp"
            android:padding="0dp"
            android:singleLine="true" />
    </LinearLayout>

</LinearLayout>
