<?xml version="1.0" encoding="utf-8"?>
<!--
    keyboard_main.xml
    ──────────────────────────────────────────────────────────────────────────
    CodeKeys IME root layout.

    IMPORTANT: The IME inflates this layout under the system's
    `Theme.DeviceDefault.InputMethod`, so we MUST NOT reference any Material
    theme attributes (?attr/colorSurface, colorPrimaryContainer, etc.) here —
    those would crash inflation. All colors are baseline fallbacks; the Java
    side overrides them at runtime via getKeyBgColor() / getAccentColor() etc.

    Architecture:
      • Suggestion strip (chips) — always at the top.
      • Optional PC keys row — togglable from settings.
      • Single content container (FrameLayout) — the active panel view
        (keyboard / emoji / clipboard / symbols) is swapped inside this
        container instead of rebuilding the whole keyboard each time.
      • Bottom action row — caps/space/enter/arrows/etc., always visible.
    ──────────────────────────────────────────────────────────────────────────
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/keyboard_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="@dimen/keyboard_root_padding_top"
    android:paddingBottom="@dimen/keyboard_root_padding_bottom"
    android:paddingStart="4dp"
    android:paddingEnd="4dp"
    android:background="#1A1A2E">

    <!-- Suggestion strip (autocomplete chips, runtime-filled) -->
    <HorizontalScrollView
        android:id="@+id/suggestion_scroll"
        android:layout_width="match_parent"
        android:layout_height="@dimen/row_suggestion_height"
        android:scrollbars="none"
        android:background="#141428">

        <LinearLayout
            android:id="@+id/row_suggestions"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />
    </HorizontalScrollView>

    <!-- Optional PC keys row (Esc/Tab/Ctrl/etc.) — toggled by settings -->
    <HorizontalScrollView
        android:id="@+id/pc_keys_scroll"
        android:layout_width="match_parent"
        android:layout_height="@dimen/row_pc_keys_height"
        android:scrollbars="none"
        android:background="#0F0F22"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/row_pc_keys"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="4dp" />
    </HorizontalScrollView>

    <!-- Single panel container — the active panel view is swapped here -->
    <FrameLayout
        android:id="@+id/panel_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent" />

    <!-- Bottom action row — settings/symbols/emoji/space/arrows/enter -->
    <LinearLayout
        android:id="@+id/row_nav"
        android:layout_width="match_parent"
        android:layout_height="@dimen/row_nav_height"
        android:orientation="horizontal"
        android:paddingStart="2dp"
        android:paddingEnd="2dp"
        android:layout_marginTop="2dp"
        android:gravity="center_vertical">

        <!-- Settings / Language popup trigger -->
        <Button
            android:id="@+id/btn_settings"
            android:layout_width="@dimen/key_action_width"
            android:layout_height="match_parent"
            android:layout_margin="@dimen/key_margin"
            android:text="⚙"
            android:textSize="16sp"
            android:textColor="#00E5FF"
            android:background="#252545"
            android:padding="0dp" />

        <!-- Symbols panel toggle (?123) -->
        <Button
            android:id="@+id/btn_symbols_panel"
            android:layout_width="@dimen/key_action_width"
            android:layout_height="match_parent"
            android:layout_margin="@dimen/key_margin"
            android:text="#123"
            android:textSize="11sp"
            android:textColor="#E8E8FF"
            android:background="#252545" />

        <!-- Emoji panel -->
        <Button
            android:id="@+id/btn_emoji"
            android:layout_width="@dimen/key_action_width"
            android:layout_height="match_parent"
            android:layout_margin="@dimen/key_margin"
            android:text="☺"
            android:textSize="16sp"
            android:textColor="#E8E8FF"
            android:background="#252545" />

        <!-- Undo -->
        <ImageButton
            android:id="@+id/btn_undo"
            android:layout_width="@dimen/key_undo_width"
            android:layout_height="match_parent"
            android:layout_margin="@dimen/key_margin"
            android:src="@drawable/arrow_forward"
            android:background="#252545" />

        <!-- Space (largest weight so it dominates the row) -->
        <Button
            android:id="@+id/btn_space"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="6"
            android:layout_margin="@dimen/key_margin"
            android:text="space"
            android:textSize="12sp"
            android:textColor="#E8E8FF"
            android:background="#252545" />

        <!-- Redo -->
        <ImageButton
            android:id="@+id/btn_redo"
            android:layout_width="@dimen/key_undo_width"
            android:layout_height="match_parent"
            android:layout_margin="@dimen/key_margin"
            android:src="@drawable/arrow-back"
            android:background="#252545" />

        <!-- Arrow cluster (vertical: up/down) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:layout_marginStart="2dp">

            <ImageButton
                android:id="@+id/btn_arrow_up"
                android:layout_width="@dimen/key_arrow_width"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="1dp"
                android:src="@drawable/arrow-badge-up"
                android:background="#252545"
                android:scaleType="fitCenter" />

            <ImageButton
                android:id="@+id/btn_arrow_down"
                android:layout_width="@dimen/key_arrow_width"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="1dp"
                android:src="@drawable/arrow-badge-down"
                android:background="#252545"
                android:scaleType="fitCenter" />
        </LinearLayout>

        <!-- Arrow cluster (vertical: left/right) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:layout_marginStart="2dp">

            <ImageButton
                android:id="@+id/btn_arrow_left"
                android:layout_width="@dimen/key_arrow_width"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="1dp"
                android:src="@drawable/arrow-badge-left"
                android:background="#252545"
                android:scaleType="fitCenter" />

            <ImageButton
                android:id="@+id/btn_arrow_right"
                android:layout_width="@dimen/key_arrow_width"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="1dp"
                android:src="@drawable/arrow-badge-right"
                android:background="#252545"
                android:scaleType="fitCenter" />
        </LinearLayout>

        <!-- Enter / IME action -->
        <Button
            android:id="@+id/btn_enter"
            android:layout_width="@dimen/key_enter_width"
            android:layout_height="match_parent"
            android:layout_margin="@dimen/key_margin"
            android:text="↵"
            android:textSize="14sp"
            android:textColor="#00E5FF"
            android:background="#252545"
            android:singleLine="true" />
    </LinearLayout>

</LinearLayout>
