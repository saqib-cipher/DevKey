<?xml version="1.0" encoding="utf-8"?>
<!--
    keyboard_main.xml
    ──────────────────────────────────────────────────────────────────────────
    Material 3 Expressive coding keyboard root.

    Architecture:
      • Suggestion strip (M3 chips) — always at the top.
      • Optional PC keys row — togglable from settings.
      • Single content container (FrameLayout) — the active panel view
        (keyboard / emoji / clipboard / symbols) is swapped inside this
        container instead of rebuilding the whole keyboard each time.
      • Bottom action row — caps/space/enter/arrows/etc., always visible.

    All keys use com.google.android.material.button.MaterialButton with
    Material 3 Expressive styles. Theme attributes (colorSurface,
    colorPrimaryContainer, …) make the keyboard automatically adapt to
    the active light/dark Material You palette. Runtime code may override
    individual tints based on the user's selected accent.
    ──────────────────────────────────────────────────────────────────────────
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/keyboard_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="@dimen/keyboard_root_padding_top"
    android:paddingBottom="@dimen/keyboard_root_padding_bottom"
    android:paddingStart="4dp"
    android:paddingEnd="4dp"
    android:elevation="@dimen/keyboard_elevation"
    android:background="?attr/colorSurface">

    <!-- ══════════════════════════════════════════════════════
         Suggestion strip (autocomplete chips)
    ══════════════════════════════════════════════════════ -->
    <HorizontalScrollView
        android:id="@+id/suggestion_scroll"
        android:layout_width="match_parent"
        android:layout_height="@dimen/row_suggestion_height"
        android:scrollbars="none"
        android:background="?attr/colorSurface">

        <LinearLayout
            android:id="@+id/row_suggestions"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />
    </HorizontalScrollView>

    <!-- ══════════════════════════════════════════════════════
         Optional PC keys row — Esc Tab Ctrl Alt Shift Win F1–F12 …
         Toggleable from settings ("show_pc_keys"). Hidden by default.
    ══════════════════════════════════════════════════════ -->
    <HorizontalScrollView
        android:id="@+id/pc_keys_scroll"
        android:layout_width="match_parent"
        android:layout_height="@dimen/row_pc_keys_height"
        android:scrollbars="none"
        android:background="?attr/colorSurfaceContainer"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/row_pc_keys"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="4dp" />
    </HorizontalScrollView>

    <!-- ══════════════════════════════════════════════════════
         Single panel container — the active panel view is swapped
         in here at runtime (keyboard / symbols / emoji / clipboard).
         Height is wrap_content; rows inside scale via key_height_scale.
    ══════════════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/panel_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent" />

    <!-- ══════════════════════════════════════════════════════
         Bottom action row — settings/symbols/emoji/space/arrows/enter.
         Always visible regardless of the active panel.
    ══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/row_nav"
        android:layout_width="match_parent"
        android:layout_height="@dimen/row_nav_height"
        android:orientation="horizontal"
        android:paddingStart="2dp"
        android:paddingEnd="2dp"
        android:layout_marginTop="2dp"
        android:gravity="center_vertical">

        <!-- Settings / Language popup trigger -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_settings"
            style="@style/KeyboardKey.Special"
            android:layout_width="@dimen/key_action_width"
            android:layout_height="match_parent"
            android:layout_margin="@dimen/key_margin"
            android:text="⚙"
            android:textSize="16sp" />

        <!-- Symbols panel toggle (?123) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_symbols_panel"
            style="@style/KeyboardKey.Special"
            android:layout_width="@dimen/key_action_width"
            android:layout_height="match_parent"
            android:layout_margin="@dimen/key_margin"
            android:text="?123"
            android:textSize="11sp" />

        <!-- Emoji panel -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_emoji"
            style="@style/KeyboardKey.Special"
            android:layout_width="@dimen/key_action_width"
            android:layout_height="match_parent"
            android:layout_margin="@dimen/key_margin"
            android:text="☺"
            android:textSize="16sp" />

        <!-- Undo -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_undo"
            style="@style/KeyboardKey"
            android:layout_width="@dimen/key_undo_width"
            android:layout_height="match_parent"
            android:layout_margin="@dimen/key_margin"
            android:text="↩"
            android:textSize="14sp" />

        <!-- Space (largest weight so it dominates the row) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_space"
            style="@style/KeyboardKey.Special"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="3"
            android:layout_margin="@dimen/key_margin"
            android:text="space"
            android:textSize="12sp" />

        <!-- Redo -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_redo"
            style="@style/KeyboardKey"
            android:layout_width="@dimen/key_undo_width"
            android:layout_height="match_parent"
            android:layout_margin="@dimen/key_margin"
            android:text="↪"
            android:textSize="14sp" />

        <!-- Arrow cluster (vertical: up/down) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:layout_marginStart="2dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_arrow_up"
                style="@style/KeyboardKey.Icon"
                android:layout_width="@dimen/key_arrow_width"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="1dp"
                app:icon="@android:drawable/arrow_up_float"
                app:iconGravity="textStart"
                app:iconPadding="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_arrow_down"
                style="@style/KeyboardKey.Icon"
                android:layout_width="@dimen/key_arrow_width"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="1dp"
                app:icon="@android:drawable/arrow_down_float"
                app:iconGravity="textStart"
                app:iconPadding="0dp" />
        </LinearLayout>

        <!-- Arrow cluster (vertical: left/right) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:layout_marginStart="2dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_arrow_left"
                style="@style/KeyboardKey.Icon"
                android:layout_width="@dimen/key_arrow_width"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="1dp"
                app:icon="@android:drawable/ic_media_rew"
                app:iconGravity="textStart"
                app:iconPadding="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_arrow_right"
                style="@style/KeyboardKey.Icon"
                android:layout_width="@dimen/key_arrow_width"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="1dp"
                app:icon="@android:drawable/ic_media_ff"
                app:iconGravity="textStart"
                app:iconPadding="0dp" />
        </LinearLayout>

        <!-- Enter / IME action — special (primary container) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_enter"
            style="@style/KeyboardKey.Special"
            android:layout_width="@dimen/key_enter_width"
            android:layout_height="match_parent"
            android:layout_margin="@dimen/key_margin"
            android:text="↵"
            android:textSize="14sp"
            android:singleLine="true" />
    </LinearLayout>

</LinearLayout>
