<?xml version="1.0" encoding="utf-8"?>
<!--
    panel_cursor.xml — full-panel cursor controller.

    Shown when the user taps the single "cursor" button in Gboard-style
    mode. Replaces the keyboard panel (FrameLayout @id/panel_container)
    with a generous D-pad so cursor work doesn't squeeze into a 26dp
    touch target. Each direction repeats while held (the IME attaches a
    long-press handler in code, mirroring the backspace pattern).

    Layout (every button is now an ImageButton tinted at runtime):
      ┌──────────────┬────────┬──────────────┐
      │  text-cursor │   ▲    │   ⤒ doc top  │
      │  ▢ all       ├────────┤   |← line s. │
      │  ⧉ copy      │  ◀  ▶  │   →| line e. │
      │  ⎘ paste     │   ▼    │   ⤓ doc end  │
      │              │        │   ⌫ backsp.  │
      └──────────────┴────────┴──────────────┘

    The "ABC — back to keyboard" affordance lives on the bottom action
    row's space bar (it's relabelled while CURSOR mode is active), so the
    panel itself doesn't need a dedicated close button. Tapping space
    returns to the keyboard panel.

    All colors are baseline #252545 / #E8E8FF — Java overrides them at
    runtime to track the user's accent + key colors, just like the
    keyboard panel.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="6dp">

    <!-- ── Left column: selection / clipboard helpers ── -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginEnd="4dp">

        <ImageButton
            android:id="@+id/cursor_btn_select_toggle"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="3dp"
            android:src="@drawable/text_select"
            android:scaleType="fitCenter"
            android:padding="14dp"
            android:background="#252545"
            android:contentDescription="Toggle selection mode" />

        <ImageButton
            android:id="@+id/cursor_btn_select_all"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="3dp"
            android:src="@drawable/select_all"
            android:scaleType="fitCenter"
            android:padding="14dp"
            android:background="#252545"
            android:contentDescription="Select all" />

        <ImageButton
            android:id="@+id/cursor_btn_copy"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="3dp"
            android:src="@drawable/copy"
            android:scaleType="fitCenter"
            android:padding="14dp"
            android:background="#252545"
            android:contentDescription="Copy" />

        <ImageButton
            android:id="@+id/cursor_btn_paste"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:src="@drawable/clipboard_paste"
            android:scaleType="fitCenter"
            android:padding="14dp"
            android:background="#252545"
            android:contentDescription="Paste" />
    </LinearLayout>

    <!-- ── Center column: D-pad ── -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.4"
        android:orientation="vertical"
        android:layout_marginStart="2dp"
        android:layout_marginEnd="2dp">

        <ImageButton
            android:id="@+id/cursor_btn_up"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="3dp"
            android:src="@drawable/arrow_badge_up"
            android:scaleType="fitCenter"
            android:padding="14dp"
            android:background="#252545"
            android:contentDescription="Up" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="2"
            android:layout_marginBottom="3dp"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/cursor_btn_left"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="3dp"
                android:src="@drawable/arrow_badge_left"
                android:scaleType="fitCenter"
                android:padding="14dp"
                android:background="#252545"
                android:contentDescription="Left" />

            <ImageButton
                android:id="@+id/cursor_btn_right"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:src="@drawable/arrow_badge_right"
                android:scaleType="fitCenter"
                android:padding="14dp"
                android:background="#252545"
                android:contentDescription="Right" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/cursor_btn_down"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:src="@drawable/arrow_badge_down"
            android:scaleType="fitCenter"
            android:padding="14dp"
            android:background="#252545"
            android:contentDescription="Down" />
    </LinearLayout>

    <!-- ── Right column: jump targets + backspace ──
         text-start / text-end are the document-level Ctrl+Home /
         Ctrl+End equivalents; line-start / line-end keep the
         move-Home / move-End behaviour for line-level navigation. -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="4dp">

        <ImageButton
            android:id="@+id/cursor_btn_text_start"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="3dp"
            android:src="@drawable/chevrons_up"
            android:scaleType="fitCenter"
            android:padding="14dp"
            android:background="#252545"
            android:contentDescription="Move cursor to first character" />

        <ImageButton
            android:id="@+id/cursor_btn_home"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="3dp"
            android:src="@drawable/line_start"
            android:scaleType="fitCenter"
            android:padding="14dp"
            android:background="#252545"
            android:contentDescription="Line start" />

        <ImageButton
            android:id="@+id/cursor_btn_end"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="3dp"
            android:src="@drawable/line_end"
            android:scaleType="fitCenter"
            android:padding="14dp"
            android:background="#252545"
            android:contentDescription="Line end" />

        <ImageButton
            android:id="@+id/cursor_btn_text_end"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="3dp"
            android:src="@drawable/chevrons_down"
            android:scaleType="fitCenter"
            android:padding="14dp"
            android:background="#252545"
            android:contentDescription="Move cursor to last position" />

        <ImageButton
            android:id="@+id/cursor_btn_backspace"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:src="@drawable/backspace"
            android:scaleType="fitCenter"
            android:padding="12dp"
            android:background="#252545"
            android:contentDescription="Backspace" />
    </LinearLayout>
</LinearLayout>
