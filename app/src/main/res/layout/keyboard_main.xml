<?xml version="1.0" encoding="utf-8"?>
<!--
    keyboard_main.xml
    ──────────────────────────────────────────────────────────────────────────
    CodeKeys IME root layout.

    IMPORTANT: The IME inflates this layout under the system's
    `Theme.DeviceDefault.InputMethod`, so we MUST NOT reference any Material
    theme attributes (?attr/colorSurface, colorPrimaryContainer, etc.) here —
    those would crash inflation. All colors are baseline fallbacks; the Java
    side overrides them at runtime via getKeyBgColor() / getAccentColor() etc.

    Architecture:
      • Suggestion strip (chips) — always at the top.
      • Optional PC keys row — togglable from settings.
      • Single content container (FrameLayout) — the active panel view
        (keyboard / emoji / clipboard / symbols) is swapped inside this
        container instead of rebuilding the whole keyboard each time.
      • Bottom action row — caps/space/enter/arrows/etc., always visible.

    Theme matching:
      • Sub-rows use transparent backgrounds so the user's chosen theme
        bg_color shows through uniformly across suggestion / symbols /
        snippet / number rows.
      • Action-row buttons use Tabler-style drawable icons (tinted at
        runtime to the user's text/accent colors) instead of glyphs so
        the look stays crisp at every theme.
    ──────────────────────────────────────────────────────────────────────────
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/keyboard_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="@dimen/keyboard_root_padding_top"
    android:paddingBottom="@dimen/keyboard_root_padding_bottom"
    android:paddingStart="4dp"
    android:paddingEnd="4dp"
    android:background="#1A1A2E">

    <!-- Suggestion strip (autocomplete chips, runtime-filled).
         Transparent bg so the keyboard theme is visible underneath. -->
    <HorizontalScrollView
        android:id="@+id/suggestion_scroll"
        android:layout_width="match_parent"
        android:layout_height="@dimen/row_suggestion_height"
        android:scrollbars="none"
        android:background="@android:color/transparent">

        <LinearLayout
            android:id="@+id/row_suggestions"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="6dp"
            android:paddingEnd="6dp" />
    </HorizontalScrollView>

    <!-- Optional PC keys row (Esc/Tab/Ctrl/etc.) — toggled by settings -->
    <HorizontalScrollView
        android:id="@+id/pc_keys_scroll"
        android:layout_width="match_parent"
        android:layout_height="@dimen/row_pc_keys_height"
        android:scrollbars="none"
        android:background="@android:color/transparent"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/row_pc_keys"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="4dp" />
    </HorizontalScrollView>

    <!-- Single panel container — the active panel view is swapped here -->
    <FrameLayout
        android:id="@+id/panel_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent" />

    <!-- Bottom action row — settings/symbols/emoji/space/arrows/enter -->
    <LinearLayout
        android:id="@+id/row_nav"
        android:layout_width="match_parent"
        android:layout_height="@dimen/row_nav_height"
        android:orientation="horizontal"
        android:paddingStart="2dp"
        android:paddingEnd="2dp"
        android:layout_marginTop="2dp"
        android:gravity="center_vertical">

        <!-- Symbols panel toggle (?123 — math symbols icon).
             Placed first to put the high-frequency control under the thumb;
             settings sits to its right since it's the rarer interaction. -->
        <ImageButton
            android:id="@+id/btn_symbols_panel"
            android:layout_width="@dimen/key_action_width"
            android:layout_height="match_parent"
            android:layout_margin="@dimen/key_margin"
            android:src="@drawable/math_symbols"
            android:scaleType="fitCenter"
            android:padding="10dp"
            android:background="#252545"
            android:contentDescription="Symbols" />

        <!-- Settings / Language popup trigger.
             Hidden when "Gboard-Style Bottom Row" is on (Java toggles
             visibility) — settings is reachable via long-press on comma. -->
        <ImageButton
            android:id="@+id/btn_settings"
            android:layout_width="@dimen/key_action_width"
            android:layout_height="match_parent"
            android:layout_margin="@dimen/key_margin"
            android:src="@drawable/settings_2"
            android:scaleType="fitCenter"
            android:padding="10dp"
            android:background="#252545"
            android:contentDescription="Settings" />

        <!-- Emoji panel. Hidden in Gboard-style mode (the symbols button
             carries the Gboard "?123" role; emoji is reachable via the
             language popup triggered by long-pressing the comma). -->
        <ImageButton
            android:id="@+id/btn_emoji"
            android:layout_width="@dimen/key_action_width"
            android:layout_height="match_parent"
            android:layout_margin="@dimen/key_margin"
            android:src="@drawable/mood_smile"
            android:scaleType="fitCenter"
            android:padding="9dp"
            android:background="#252545"
            android:contentDescription="Emoji" />

        <!-- Comma (Gboard-style bottom row). Hidden by default; Java
             reveals it when the gboard_style_row pref is enabled. -->
        <Button
            android:id="@+id/btn_comma"
            android:layout_width="@dimen/key_action_width"
            android:layout_height="match_parent"
            android:layout_margin="@dimen/key_margin"
            android:text=","
            android:textSize="18sp"
            android:textColor="#E8E8FF"
            android:textAllCaps="false"
            android:background="#252545"
            android:visibility="gone"
            android:contentDescription="Comma" />

        <!-- Undo -->
        <ImageButton
            android:id="@+id/btn_undo"
            android:layout_width="@dimen/key_undo_width"
            android:layout_height="match_parent"
            android:layout_margin="@dimen/key_margin"
            android:src="@drawable/arrow_back_up"
            android:scaleType="fitCenter"
            android:padding="8dp"
            android:background="#252545"
            android:contentDescription="Undo" />

        <!-- Space (largest weight so it dominates the row) -->
        <Button
            android:id="@+id/btn_space"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="6"
            android:layout_margin="@dimen/key_margin"
            android:text="space"
            android:textSize="12sp"
            android:textColor="#E8E8FF"
            android:background="#252545" />

        <!-- Period (Gboard-style bottom row). Mirrors btn_comma on the
             right of space. Long-press toggles the cursor controller panel
             (one button instead of the four-arrow cluster). -->
        <Button
            android:id="@+id/btn_period"
            android:layout_width="@dimen/key_action_width"
            android:layout_height="match_parent"
            android:layout_margin="@dimen/key_margin"
            android:text="."
            android:textSize="18sp"
            android:textColor="#E8E8FF"
            android:textAllCaps="false"
            android:background="#252545"
            android:visibility="gone"
            android:contentDescription="Period" />

        <!-- Redo -->
        <ImageButton
            android:id="@+id/btn_redo"
            android:layout_width="@dimen/key_undo_width"
            android:layout_height="match_parent"
            android:layout_margin="@dimen/key_margin"
            android:src="@drawable/arrow_forward_up"
            android:scaleType="fitCenter"
            android:padding="8dp"
            android:background="#252545"
            android:contentDescription="Redo" />

        <!-- Up/Down arrow cluster — hidden in Gboard-style mode.
             The id `arrow_cluster_vertical` lets Java toggle the whole
             cluster (including its margins) rather than each child. -->
        <LinearLayout
            android:id="@+id/arrow_cluster_vertical"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:layout_marginStart="2dp">

            <ImageButton
                android:id="@+id/btn_arrow_up"
                android:layout_width="@dimen/key_arrow_width"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="1dp"
                android:src="@drawable/arrow_badge_up"
                android:background="#252545"
                android:scaleType="fitCenter" />

            <ImageButton
                android:id="@+id/btn_arrow_down"
                android:layout_width="@dimen/key_arrow_width"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="1dp"
                android:src="@drawable/arrow_badge_down"
                android:background="#252545"
                android:scaleType="fitCenter" />
        </LinearLayout>

        <!-- Left/Right arrow cluster — see arrow_cluster_vertical above. -->
        <LinearLayout
            android:id="@+id/arrow_cluster_horizontal"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:layout_marginStart="2dp">

            <ImageButton
                android:id="@+id/btn_arrow_left"
                android:layout_width="@dimen/key_arrow_width"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="1dp"
                android:src="@drawable/arrow_badge_left"
                android:background="#252545"
                android:scaleType="fitCenter" />

            <ImageButton
                android:id="@+id/btn_arrow_right"
                android:layout_width="@dimen/key_arrow_width"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="1dp"
                android:src="@drawable/arrow_badge_right"
                android:background="#252545"
                android:scaleType="fitCenter" />
        </LinearLayout>

        <!-- Single-button cursor toggle — only visible in Gboard-style
             mode. Tapping it replaces the keyboard panel with a generous
             D-pad controller (CURSOR PanelMode); tapping again returns to
             the keyboard. Lets the bottom row stay uncluttered while
             keeping cursor control one tap away. -->
        <ImageButton
            android:id="@+id/btn_cursor_panel"
            android:layout_width="@dimen/key_action_width"
            android:layout_height="match_parent"
            android:layout_margin="@dimen/key_margin"
            android:src="@drawable/arrow_badge_right"
            android:scaleType="fitCenter"
            android:padding="8dp"
            android:background="#252545"
            android:visibility="gone"
            android:contentDescription="Cursor controller" />

        <!-- Enter / IME action (icon by default; switched to text label
             at runtime when the active EditText specifies an IME action).
             Stays a Button so the IME service can swap its label between
             ↵ / Go / Done / Search / Send via setText(). -->
        <Button
            android:id="@+id/btn_enter"
            android:layout_width="@dimen/key_enter_width"
            android:layout_height="match_parent"
            android:layout_margin="@dimen/key_margin"
            android:text=""
            android:textSize="14sp"
            android:textColor="#00E5FF"
            android:textAllCaps="false"
            android:background="#252545"
            android:singleLine="true" />
    </LinearLayout>

</LinearLayout>
