<?xml version="1.0" encoding="utf-8"?>
<!--
    dimens.xml
    ──────────────────────────────────────────────────────────────────────────
    Centralised spacing and sizing tokens for the keyboard.

    Anything that's used across multiple layouts lives here so the look stays
    consistent. The Java side scales rows by `key_height_scale` at runtime,
    so values here are the *baseline* heights at scale = 1.0.

    Sizes were tuned to match Gboard's default phone layout: lower row
    heights, tighter horizontal margins, slightly larger enter / backspace
    so the bottom row doesn't feel cramped, and chip / suggestion heights
    that follow Gboard's suggestion strip.
    ──────────────────────────────────────────────────────────────────────────
-->
<resources>

    <!-- Keyboard root padding — keep small so the keyboard isn't bottom-heavy. -->
    <dimen name="keyboard_root_padding_top">3dp</dimen>
    <dimen name="keyboard_root_padding_bottom">5dp</dimen>
    <dimen name="keyboard_elevation">3dp</dimen>

    <!-- Row heights (baseline — scaled at runtime). Tuned to Gboard's
         default phone layout: shorter letter rows so the keyboard
         occupies less of the screen when the user opts in to "Match
         Gboard" sizing via the height-scale slider. -->
    <dimen name="row_suggestion_height">40dp</dimen>
    <dimen name="row_pc_keys_height">36dp</dimen>
    <dimen name="row_symbol_height">40dp</dimen>
    <dimen name="row_snippet_height">36dp</dimen>
    <dimen name="row_number_height">38dp</dimen>
    <dimen name="row_letter_height">52dp</dimen>
    <dimen name="row_nav_height">52dp</dimen>

    <!-- Key sizing & spacing — tighter margins so adjacent keys read as a
         continuous strip the way Gboard does, with rounded corners. -->
    <dimen name="key_corner_radius">8dp</dimen>
    <dimen name="key_padding_h">4dp</dimen>
    <dimen name="key_padding_v">3dp</dimen>
    <dimen name="key_margin">3dp</dimen>
    <dimen name="key_letter_text_size">20sp</dimen>

    <!-- Special keys (caps / backspace / nav row).
         Backspace / shift are 1.4× a normal key so they line up under the
         bottom row of the QWERTY block — same proportion Gboard uses. -->
    <dimen name="key_special_width">44dp</dimen>
    <dimen name="key_backspace_width">50dp</dimen>
    <!-- Bottom action row keys: trimmed so the space bar can claim more width. -->
    <dimen name="key_action_width">36dp</dimen>
    <dimen name="key_undo_width">30dp</dimen>
    <dimen name="key_arrow_width">26dp</dimen>
    <dimen name="key_enter_width">52dp</dimen>

    <!-- Chips — slightly taller so they read as proper Gboard-style pills. -->
    <dimen name="chip_corner_radius">18dp</dimen>
    <dimen name="chip_height">34dp</dimen>

    <!-- Card surfaces (clipboard) -->
    <dimen name="card_corner_radius">16dp</dimen>
    <dimen name="card_padding">10dp</dimen>
    <dimen name="card_margin">4dp</dimen>

    <!-- Emoji panel -->
    <dimen name="emoji_search_height">46dp</dimen>
    <dimen name="emoji_tab_height">40dp</dimen>
    <dimen name="emoji_tab_width">52dp</dimen>
    <dimen name="emoji_grid_height">220dp</dimen>
    <dimen name="emoji_cell_height">42dp</dimen>

    <!-- Clipboard panel -->
    <dimen name="clipboard_header_height">42dp</dimen>
    <dimen name="clipboard_list_height">220dp</dimen>

</resources>
